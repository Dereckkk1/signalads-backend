# ===========================================
# CONFIGURAÇÕES DO SERVIDOR
# ===========================================

# Banco de Dados MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/database

# Porta do servidor backend
PORT=5000
API_URL=http://localhost:5000

# Chave secreta para JWT (gere uma aleatória e segura)
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_em_producao

# Ambiente (development | production)
NODE_ENV=development

# ===========================================
# WALLET DA PLATAFORMA
# ===========================================

# ID da wallet da plataforma (não alterar)
PLATFORM_USER_ID=platform

# ===========================================
# GOOGLE CLOUD STORAGE
# ===========================================

# ID do projeto no Google Cloud
GOOGLE_CLOUD_PROJECT_ID=seu-projeto-id

# Caminho para o arquivo de credenciais JSON
GOOGLE_CLOUD_KEY_FILE=./credentials/seu-arquivo-credentials.json

# Nome do bucket para armazenar arquivos
GOOGLE_CLOUD_BUCKET_NAME=seu-bucket-name

# ===========================================
# ASAAS PAYMENT GATEWAY
# ===========================================

# Ambiente do Asaas (sandbox | production)
ASAAS_ENVIRONMENT=sandbox

# URL da API Asaas
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# API Key do Asaas
# Sandbox: $aact_hmlg_...
# Produção: $aact_prod_...
ASAAS_API_KEY=sua_api_key_aqui

# Webhook URL para receber notificações do Asaas
WEBHOOK_URL=https://seu-dominio.com.br/api/webhook/asaas

# Token de autenticação do webhook (gere um aleatório)
WEBHOOK_AUTH_TOKEN=seu-token-webhook-seguro

# ===========================================
# EMAIL (NODEMAILER)
# ===========================================

# Configurações SMTP
# Para Gmail:
# 1. Ative verificação em 2 etapas: https://myaccount.google.com/security
# 2. Crie senha de app: https://myaccount.google.com/apppasswords
# 3. Use a senha de app abaixo (não a senha normal)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua_senha_de_app_aqui
SMTP_FROM=E-rádios <seu-email@gmail.com>

# ===========================================
# URL DO FRONTEND
# ===========================================

# URL base do frontend (para links nos emails)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com.br
FRONTEND_URL=http://localhost:3000

# ===========================================
# DADOS DE FATURAMENTO DA PLATAFORMA
# ===========================================

# Dados da empresa E-rádios para emissoras emitirem NF
# Esses dados são enviados às emissoras quando um pedido "A Faturar" é aprovado
# As emissoras emitem NF CONTRA a plataforma (tomador do serviço)

PLATFORM_RAZAO_SOCIAL=E-rádios Tecnologia Ltda
PLATFORM_CNPJ=00.000.000/0001-00
PLATFORM_ADDRESS=Rua Exemplo, 123 - Centro - São Paulo/SP - CEP 01000-000
PLATFORM_BILLING_EMAIL=financeiro@E-rádios.com.br
PLATFORM_PHONE=(11) 0000-0000

# ===========================================
# OBSERVAÇÕES IMPORTANTES
# ===========================================

# 🔒 SEGURANÇA:
# - NUNCA commite o arquivo .env no Git
# - Use senhas fortes e aleatórias
# - Gere JWT_SECRET com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# - Gere WEBHOOK_AUTH_TOKEN com método similar

# 📧 EMAIL:
# - Para testes locais, deixe SMTP_USER vazio (emails logados no console)
# - Para produção, configure SMTP real (Gmail, SendGrid, AWS SES, etc.)

# 💳 PAGAMENTOS:
# - Use sandbox do Asaas em desenvolvimento
# - Troque para produção apenas quando testar tudo

# 📦 STORAGE:
# - Se não configurar GCS, sistema usa armazenamento local (pasta uploads/)
# - Para produção, sempre configure GCS
