# ===========================================
# CONFIGURAÇÕES DO SERVIDOR
# ===========================================

# Banco de Dados MongoDB Atlas
MONGODB_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/?appName=YourApp

# Porta do servidor backend
PORT=5000
API_URL=http://localhost:5000

# URL do Redis (rate-limit + cache). Para autenticar use redis://:password@host:porta/db
REDIS_URL=redis://localhost:6379/1

# Chave secreta para JWT (gere uma aleatória e segura)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here-generate-with-crypto-randomBytes

# Ambiente (development | production | test)
NODE_ENV=development

# Domínio dos cookies de autenticação (CSRF, access_token, refresh_token)
# Produção: .eradios.com.br (com ponto — compartilha entre subdomínios)
# Desenvolvimento: não definir (usa localhost automaticamente)
# COOKIE_DOMAIN=.eradios.com.br

# ===========================================
# IDS DE SISTEMA
# ===========================================

# ID da plataforma (não alterar)
PLATFORM_USER_ID=platform

# ID do usuario de Suporte (referenciado por outras features)
SUPPORT_USER_ID=your-support-user-id-here

# Email do admin (usado em alguns scripts/utilities)
ADMIN_EMAIL=admin@example.com

# ===========================================
# GOOGLE CLOUD STORAGE
# ===========================================

# ID do projeto no Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Caminho para o arquivo de credenciais JSON (NUNCA commitar)
GOOGLE_CLOUD_KEY_FILE=./credentials/your-service-account-key.json

# Nome do bucket para armazenar arquivos
GOOGLE_CLOUD_BUCKET_NAME=your-bucket-name

# ===========================================
# EMAIL (NODEMAILER)
# ===========================================

# Configurações SMTP
# Para Gmail:
# 1. Ative verificação em 2 etapas: https://myaccount.google.com/security
# 2. Crie senha de app: https://myaccount.google.com/apppasswords
# 3. Use a senha de app abaixo (não a senha normal)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=E-rádios <your-email@gmail.com>

# ===========================================
# URL DO FRONTEND
# ===========================================

# URL base do frontend (para links nos emails)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com.br
FRONTEND_URL=http://localhost:3000

# ===========================================
# OPENAI (assistente de IA)
# ===========================================

# Chave da API da OpenAI (usada por features de IA)
# Gere em: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# ===========================================
# IMAGEM ASSINATURA APPSHEET
# ===========================================

# Signature usada para validar/montar URLs de imagens proxy
IMAGE_SIGNATURE=your-image-signature-here

# ===========================================
# OBSERVAÇÕES IMPORTANTES
# ===========================================

# 🔒 SEGURANÇA:
# - NUNCA commite o arquivo .env no Git
# - Use senhas fortes e aleatórias
# - Gere JWT_SECRET com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# - Após qualquer suspeita de exposição, rotacione TODAS as chaves no provedor

# 📧 EMAIL:
# - Para testes locais, deixe SMTP_USER vazio (emails logados no console)
# - Para produção, configure SMTP real (Gmail, SendGrid, etc.)

# 📦 STORAGE:
# - Se não configurar GCS, sistema usa armazenamento local (pasta uploads/)
# - Para produção, sempre configure GCS
